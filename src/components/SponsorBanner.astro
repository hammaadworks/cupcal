---
// src/components/SponsorBanner.astro
---

<div class="w-full bg-blue-600 border-y-[4px] border-black text-black py-3 overflow-hidden relative group block hover:bg-yellow-300 transition-colors cursor-pointer">
  <a 
    href="mailto:sponsor@cupcal.online?subject=Sponsorship Inquiry" 
    class="flex items-center justify-center gap-4 animate-marquee whitespace-nowrap"
    data-umami-event="sponsor_click"
    data-umami-event-position="top_banner"
  >
    <span class="text-xl md:text-2xl font-black uppercase tracking-widest" style="font-family: 'Outfit', sans-serif;">
      🚨 THIS SPOT IS AVAILABLE FOR SPONSORSHIP 🚨 
    </span>
    <span class="text-lg md:text-xl font-bold border-[2px] border-black px-4 py-1 bg-white hover:bg-black hover:text-white transition-colors uppercase">
      Reach millions of fans! Click here
    </span>
    <span class="text-xl md:text-2xl font-black uppercase tracking-widest" style="font-family: 'Outfit', sans-serif;">
      🚨 THIS SPOT IS AVAILABLE FOR SPONSORSHIP 🚨 
    </span>
  </a>
</div>

<style>
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(20%); }
    100% { transform: translateX(-80%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
    }
  }
</style>
