---
interface Props {
  match: {
    id: string;
    date: string;
    homeTeam: string;
    awayTeam: string;
    venue: string;
    group: string;
    stage: string;
  };
}

const { match } = Astro.props;
---

<div class="match-card group p-6 bg-white border border-slate-100 rounded-2xl shadow-sm hover:shadow-md transition-all">
  <div class="flex justify-between items-start mb-4">
    <div class="flex flex-col">
      <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest">{match.stage} • Group {match.group}</span>
      <span class="text-sm text-slate-500 font-medium match-date" data-utc={match.date}>
        {new Date(match.date).toLocaleDateString()}
      </span>
    </div>
    <div class="bg-slate-50 px-3 py-1 rounded-full border border-slate-100">
      <span class="text-xs font-semibold text-slate-600 match-time" data-utc={match.date}>
        {new Date(match.date).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
      </span>
    </div>
  </div>

  <div class="flex items-center justify-between gap-4 py-4">
    <div class="flex-1 text-center">
      <div class="w-16 h-16 mx-auto mb-3 bg-slate-50 rounded-full flex items-center justify-center border border-slate-100">
        <span class="text-2xl">🏳️</span>
      </div>
      <h3 class="font-bold text-lg text-slate-900">{match.homeTeam}</h3>
    </div>
    
    <div class="flex flex-col items-center">
      <span class="text-xl font-black text-slate-300">VS</span>
    </div>

    <div class="flex-1 text-center">
      <div class="w-16 h-16 mx-auto mb-3 bg-slate-50 rounded-full flex items-center justify-center border border-slate-100">
        <span class="text-2xl">🏳️</span>
      </div>
      <h3 class="font-bold text-lg text-slate-900">{match.awayTeam}</h3>
    </div>
  </div>

  <div class="mt-4 pt-4 border-t border-slate-50 flex justify-between items-center">
    <span class="text-xs text-slate-400 italic flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {match.venue}
    </span>
    <button class="text-xs font-bold text-indigo-600 hover:text-indigo-800 transition-colors uppercase tracking-tight">
      Get Alerts
    </button>
  </div>
</div>

<script>
  // Simple localization script
  function localizeTimes() {
    const dates = document.querySelectorAll('.match-date');
    const times = document.querySelectorAll('.match-time');

    dates.forEach(el => {
      const utc = el.getAttribute('data-utc');
      if (utc) {
        el.textContent = new Date(utc).toLocaleDateString(undefined, {
          weekday: 'short',
          month: 'short',
          day: 'numeric'
        });
      }
    });

    times.forEach(el => {
      const utc = el.getAttribute('data-utc');
      if (utc) {
        el.textContent = new Date(utc).toLocaleTimeString(undefined, {
          hour: '2-digit',
          minute: '2-digit'
        });
      }
    });
  }

  // Run on load and whenever Astro swaps content
  localizeTimes();
  document.addEventListener('astro:after-swap', localizeTimes);
</script>
