---
---
<section class="relative pt-32 pb-20 overflow-hidden min-h-[90vh] flex flex-col items-center justify-center bg-[#041006]">
  
  <!-- Cinematic Pitch Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="cinematic-pitch"></div>
    <div class="stadium-light left"></div>
    <div class="stadium-light right"></div>
    
    <!-- Vignette to blend into the rest of the app -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#041006] z-10"></div>
  </div>

  <div class="container px-4 mx-auto relative z-20">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/30 text-green-400 font-bold text-xs uppercase tracking-widest mb-8 backdrop-blur-md shadow-[0_0_20px_rgba(34,197,94,0.3)]">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        Summer 2026 • Live Schedule
      </div>
      
      <h1 class="mb-6 text-6xl md:text-8xl lg:text-[120px] font-black tracking-tighter text-white leading-[0.9] drop-shadow-2xl" style="font-family: 'Outfit', sans-serif;">
        THE <span class="text-transparent bg-clip-text bg-gradient-to-b from-green-400 to-emerald-700">GLOBAL</span><br />
        PITCH
      </h1>
      
      <p class="mb-12 text-lg md:text-2xl text-emerald-100/70 font-medium leading-relaxed max-w-3xl mx-auto drop-shadow-lg">
        104 Matches. 48 Teams. The ultimate fan-centric schedule. 
        <br class="hidden md:block" />
        Filter instantly. Sync locally. Never miss a kickoff.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#schedule" class="group flex items-center justify-center gap-3 w-full sm:w-auto px-8 py-4 text-lg font-black text-[#041006] bg-green-400 rounded-full hover:bg-green-300 hover:scale-105 transition-all shadow-[0_0_30px_rgba(34,197,94,0.4)] uppercase tracking-wider">
          View Fixtures
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
  
  <!-- Floating footballs/flags -->
  <div class="hidden md:flex absolute top-1/4 left-10 lg:left-20 w-24 h-24 bg-white/5 border border-white/10 rounded-full backdrop-blur-md items-center justify-center rotate-12 animate-pulse shadow-[0_0_30px_rgba(34,197,94,0.1)] z-20">
    <span class="text-4xl drop-shadow-xl">⚽</span>
  </div>
  <div class="hidden md:flex absolute bottom-1/4 right-10 lg:right-20 w-32 h-32 bg-white/5 border border-white/10 rounded-full backdrop-blur-md items-center justify-center -rotate-12 animate-[pulse_4s_infinite] shadow-[0_0_30px_rgba(34,197,94,0.1)] z-20">
    <span class="text-5xl drop-shadow-xl">🏟️</span>
  </div>
</section>
