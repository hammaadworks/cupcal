---
import faqData from '../data/seo/faq.json';
import MorphingLogo from './MorphingLogo';
---
<footer class="py-16 border-t-[4px] border-black relative z-20 bg-yellow-300">
    <div class="container px-4 mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <MorphingLogo client:load className="w-12 h-12" />
                    <h3 class="text-3xl font-outfit uppercase tracking-widest text-black">CUPCAL</h3>
                </div>
                <p class="text-black font-bold mb-4">The ultimate, vibe-heavy schedule for the 2026 Global Football Tournament.</p>
                <div class="flex gap-4">
                    <a href="https://x.com/hammaadworks" class="text-black font-outfit uppercase tracking-widest hover:text-blue-700 transition-colors">X (Twitter)</a>
                    <a href="https://github.com/hammaadworks" class="text-black font-outfit uppercase tracking-widest hover:text-blue-700 transition-colors">GitHub</a>
                </div>
            </div>
            
            <div>
                <h3 class="text-xl font-outfit uppercase tracking-widest text-black mb-4">Explore</h3>
                <ul class="space-y-2 font-bold text-black">
                    <li><a href="/" class="hover:text-blue-700 transition-colors">Schedule & Matches</a></li>
                    <li><a href="/tree" class="hover:text-blue-700 transition-colors">Tournament Tree (Finals)</a></li>
                    <li><a href="/watch-party" class="hover:text-blue-700 transition-colors">Watch Parties</a></li>
                    <li><a href="/stats" class="hover:text-blue-700 transition-colors">Open Stats</a></li>
                    <li><a href="/blog" class="hover:text-blue-700 transition-colors">Guides & Lore</a></li>
                </ul>
            </div>

            <div>
                <h3 class="text-xl font-outfit uppercase tracking-widest text-black mb-4">Sponsors</h3>
                <p class="text-black font-bold mb-2">Want to reach millions of football fans?</p>
                <a href="mailto:sponsor@cupcal.com" class="inline-block bg-black text-white px-4 py-2 rounded font-outfit uppercase tracking-widest hover:bg-blue-700 hover:-translate-y-1 hover:shadow-[4px_4px_0px_#2E0D23] transition-all">Become a Sponsor</a>
            </div>

            <div>
                <h3 class="text-xl font-outfit uppercase tracking-widest text-black mb-4">Top FAQs</h3>
                <ul class="space-y-2 font-bold text-black text-sm">
                    {faqData.slice(0, 4).map(faq => (
                        <li><a href={`/faq/${faq.slug}`} class="hover:text-blue-700 transition-colors line-clamp-1">{faq.question}</a></li>
                    ))}
                    <li class="pt-2"><a href="/faq" class="text-blue-700 underline hover:text-black transition-colors uppercase font-outfit tracking-widest">View All FAQs →</a></li>
                </ul>
            </div>
        </div>

        <div class="text-center pt-8 border-t-[3px] border-black text-black font-outfit uppercase tracking-widest">
            <p>Cooked up with Alhamdulillah by <a href="https://hammaadworks.com" class="text-blue-700 hover:text-black border-b-[2px] border-blue-700 hover:border-black transition-colors">hammaadworks</a></p>
        </div>
    </div>
</footer>
