---
import MorphingLogo from './MorphingLogo';
---
<footer class="py-16 border-t-[4px] border-black relative z-20 bg-gradient-to-r from-[#E51921] via-[#0A3161] to-[#00A859]">
    <div class="container px-4 mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <MorphingLogo client:load className="w-12 h-12" />
                    <h3 class="text-3xl font-outfit uppercase tracking-widest text-white">CUPCAL</h3>
                </div>
                <p class="text-white font-bold mb-4">The ultimate, vibe-heavy schedule for the 2026 Global Football Tournament.</p>
                <div class="flex gap-4">
                    <a href="https://x.com/hammaadworks" class="text-white font-outfit uppercase tracking-widest hover:text-blue-200 transition-colors">X (Twitter)</a>
                    <a href="https://github.com/hammaadworks" class="text-white font-outfit uppercase tracking-widest hover:text-blue-200 transition-colors">GitHub</a>
                </div>
            </div>
            
            <div>
                <h3 class="text-xl font-outfit uppercase tracking-widest text-white mb-4">Explore</h3>
                <ul class="space-y-2 font-bold text-white">
                    <li><a href="/" class="hover:text-blue-200 transition-colors">Schedule & Matches</a></li>
                    <li><a href="/tree" class="hover:text-blue-200 transition-colors">Tournament Tree (Finals)</a></li>
                    <li><a href="/watch-party" class="hover:text-blue-200 transition-colors">Watch Parties</a></li>
                    <li><a href="/stats" class="hover:text-blue-200 transition-colors">Open Stats</a></li>
                    <li><a href="/blog" class="hover:text-blue-200 transition-colors">Guides & Lore</a></li>
                </ul>
            </div>

            <div>
                <h3 class="text-xl font-outfit uppercase tracking-widest text-white mb-4">Sponsors</h3>
                <p class="text-white font-bold mb-2">Want to reach millions of football fans?</p>
                <a href="mailto:sponsor@cupcal.com" class="inline-block bg-black text-white px-4 py-2 rounded font-outfit uppercase tracking-widest hover:bg-blue-700 hover:-translate-y-1 hover:shadow-[4px_4px_0px_#2E0D23] transition-all">Become a Sponsor</a>
            </div>


        </div>

        <div class="text-center pt-8 border-t-[3px] border-black text-white font-outfit uppercase tracking-widest">
            <p>Cooked up with Alhamdulillah by <a href="https://hammaadworks.com" class="text-blue-700 hover:text-white border-b-[2px] border-blue-700 hover:border-black transition-colors">hammaadworks</a></p>
        </div>
    </div>
</footer>
