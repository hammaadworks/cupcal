---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TicketProgress from '../../components/TicketProgress';
import { supabase } from '../../utils/supabase';

// Fetch the finals event
const { data: event } = await supabase.from('finals_events').select('*').single();

// Count paid tickets
const { count: ticketsSold } = await supabase
  .from('finals_tickets')
  .select('*', { count: 'exact', head: true })
  .eq('event_id', event?.id)
  .eq('payment_status', 'paid');

// Fallback defaults
const maxTickets = event?.max_tickets ?? 100;
const maxTicketsBuffer = event?.max_tickets_buffer ?? 20;
const priceInCents = event?.price_in_cents ?? 49900;
const eventId = event?.id ?? '';
const venueName = event?.venue_name ?? 'Local Turf, Bangalore';
const eventDate = event?.event_date ?? 'TBD (Finals Date)';
const sold = ticketsSold ?? 0;

const rules = [
  { emoji: '🚫', text: 'No alcohol — zero tolerance' },
  { emoji: '👨‍👩‍👧‍👦', text: 'Family-friendly environment' },
  { emoji: '🚭', text: 'No smoking on premises' },
  { emoji: '🏟️', text: 'Respect the venue and equipment' },
  { emoji: '🤝', text: 'Follow organizer instructions at all times' },
];

const faqs = [
  {
    q: "What's included?",
    a: 'Big screen live screening, comfortable seating, the full Finals experience with fellow fans, and good vibes all around.',
  },
  {
    q: 'Is parking available?',
    a: 'TBD — we will share parking details closer to the event date via WhatsApp.',
  },
  {
    q: 'Can I bring kids?',
    a: 'Absolutely! This is a family-friendly event. Kids are more than welcome.',
  },
  {
    q: 'Refund policy?',
    a: "Tickets are non-refundable, but they're transferable. You can pass your ticket to a friend.",
  },
];
---

<BaseLayout title="THE FINAL — World Cup 2026 Finals Watch Party" description="Join the ultimate FIFA World Cup 2026 Finals live screening in Bangalore. Family-friendly, no-alcohol watch party. Book your spot now!">
  <main class="min-h-screen relative z-10 overflow-x-hidden w-full">

    <!-- ============ HERO ============ -->
    <section class="relative py-24 md:py-32 overflow-hidden bg-black text-white">
      <!-- Animated background text -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-10">
        <div class="absolute top-1/4 left-0 whitespace-nowrap text-[20vw] font-anton uppercase tracking-tighter leading-none animate-[scroll-left_30s_linear_infinite]" style="font-family: 'Anton', sans-serif;">
          FINAL FINAL FINAL FINAL FINAL FINAL
        </div>
        <div class="absolute bottom-1/4 left-0 whitespace-nowrap text-[15vw] font-anton uppercase tracking-tighter leading-none animate-[scroll-right_35s_linear_infinite]" style="font-family: 'Anton', sans-serif;">
          WORLD CUP 2026 WORLD CUP 2026 WORLD CUP 2026
        </div>
      </div>

      <div class="container mx-auto px-4 relative z-10 text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-8 bg-yellow-300 text-black border-[3px] border-white shadow-[4px_4px_0px_rgba(255,255,255,0.3)]">
          <span class="text-sm font-black uppercase tracking-widest" style="font-family: 'Anton', sans-serif;">
            🏟️ Family-Friendly · No Alcohol · Local Turf
          </span>
        </div>

        <h1 class="text-6xl md:text-8xl lg:text-[140px] font-black tracking-tighter leading-[0.85] mb-6" style="font-family: 'Anton', sans-serif;">
          THE FINAL<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-yellow-300 to-pink-500">WHISTLE</span>
        </h1>

        <p class="text-lg md:text-2xl text-gray-300 font-medium max-w-2xl mx-auto mb-8">
          FIFA World Cup 2026 Finals · Live Screening · Bangalore
        </p>

        <a href="#tickets" class="inline-block px-10 py-4 bg-pink-500 text-white text-xl font-black uppercase tracking-wider border-[4px] border-white shadow-[6px_6px_0px_rgba(255,255,255,0.3)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] transition-all" style="font-family: 'Anton', sans-serif;">
          🎟️ GRAB YOUR TICKET
        </a>
      </div>

      <!-- Floating elements -->
      <div class="hidden md:flex absolute top-16 left-10 lg:left-20 w-20 h-20 bg-white/5 border border-white/20 rounded-full backdrop-blur-sm items-center justify-center rotate-12 animate-pulse">
        <span class="text-4xl">⚽</span>
      </div>
      <div class="hidden md:flex absolute bottom-16 right-10 lg:right-20 w-28 h-28 bg-white/5 border border-white/20 rounded-full backdrop-blur-sm items-center justify-center -rotate-12 animate-[pulse_4s_infinite]">
        <span class="text-5xl">🏆</span>
      </div>
    </section>

    <!-- ============ EVENT DETAILS ============ -->
    <section class="py-16 md:py-20 bg-white border-y-[4px] border-black">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-4xl md:text-5xl text-black text-center mb-12 tracking-tight" style="font-family: 'Anton', sans-serif;">
          THE LOWDOWN
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- What -->
          <div class="p-6 bg-pink-50 border-[3px] border-black shadow-[4px_4px_0px_#000]">
            <div class="text-3xl mb-2">📺</div>
            <h3 class="text-xl font-black text-black uppercase tracking-widest mb-1" style="font-family: 'Anton', sans-serif;">What</h3>
            <p class="text-black font-medium">Live screening of the FIFA World Cup 2026 Final on a massive screen</p>
          </div>

          <!-- Where -->
          <div class="p-6 bg-yellow-50 border-[3px] border-black shadow-[4px_4px_0px_#000]">
            <div class="text-3xl mb-2">📍</div>
            <h3 class="text-xl font-black text-black uppercase tracking-widest mb-1" style="font-family: 'Anton', sans-serif;">Where</h3>
            <p class="text-black font-medium">{venueName}</p>
          </div>

          <!-- When -->
          <div class="p-6 bg-green-50 border-[3px] border-black shadow-[4px_4px_0px_#000]">
            <div class="text-3xl mb-2">📅</div>
            <h3 class="text-xl font-black text-black uppercase tracking-widest mb-1" style="font-family: 'Anton', sans-serif;">When</h3>
            <p class="text-black font-medium">{eventDate}</p>
          </div>

          <!-- Capacity -->
          <div class="p-6 bg-purple-50 border-[3px] border-black shadow-[4px_4px_0px_#000]">
            <div class="text-3xl mb-2">🎫</div>
            <h3 class="text-xl font-black text-black uppercase tracking-widest mb-1" style="font-family: 'Anton', sans-serif;">Capacity & Price</h3>
            <p class="text-black font-medium">{maxTickets} attendees · <span class="text-pink-600 font-black">₹{priceInCents / 100}</span></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TICKET PROGRESS + CHECKOUT ============ -->
    <section id="tickets" class="py-16 md:py-20 bg-brand-primary">
      <div class="container mx-auto px-4 max-w-2xl">
        <h2 class="text-4xl md:text-5xl text-black text-center mb-10 tracking-tight" style="font-family: 'Anton', sans-serif;">
          SECURE YOUR SPOT
        </h2>

        <div class="bg-white border-[4px] border-black shadow-[8px_8px_0px_#000] p-6 md:p-10">
          <TicketProgress
            client:load
            ticketsSold={sold}
            maxTickets={maxTickets}
            maxTicketsBuffer={maxTicketsBuffer}
            priceInCents={priceInCents}
            eventId={eventId}
          />
        </div>
      </div>
    </section>

    <!-- ============ RULES & FAQ ============ -->
    <section class="py-16 md:py-20 bg-yellow-300 border-y-[4px] border-black">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

          <!-- Rules -->
          <div>
            <h2 class="text-3xl md:text-4xl text-black mb-8 tracking-tight" style="font-family: 'Anton', sans-serif;">
              GROUND RULES
            </h2>
            <div class="grid gap-4">
              {rules.map((rule) => (
                <div class="flex items-center gap-4 p-4 bg-white border-[3px] border-black shadow-[3px_3px_0px_#000]">
                  <span class="text-2xl shrink-0">{rule.emoji}</span>
                  <span class="text-black font-bold text-sm uppercase tracking-wider">{rule.text}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="text-3xl md:text-4xl text-black mb-8 tracking-tight" style="font-family: 'Anton', sans-serif;">
              GOT QUESTIONS?
            </h2>
            <div class="grid gap-4">
              {faqs.map((faq) => (
                <details class="group bg-white border-[3px] border-black shadow-[3px_3px_0px_#000] cursor-pointer">
                  <summary class="p-4 text-black font-black text-sm uppercase tracking-wider list-none flex items-center justify-between" style="font-family: 'Anton', sans-serif;">
                    {faq.q}
                    <span class="text-xl group-open:rotate-45 transition-transform duration-200 ml-2">+</span>
                  </summary>
                  <div class="px-4 pb-4 text-sm text-gray-800 font-medium border-t-[2px] border-black pt-3">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SPONSOR CTA ============ -->
    <section class="py-16 md:py-20 bg-black text-white">
      <div class="container mx-auto px-4 max-w-2xl text-center">
        <h2 class="text-4xl md:text-5xl mb-4 tracking-tight" style="font-family: 'Anton', sans-serif;">
          WANT TO <span class="text-yellow-300">SPONSOR</span> THIS EVENT?
        </h2>
        <p class="text-lg text-gray-300 font-medium mb-8">
          Get your brand in front of passionate football fans. Reach out and let's make it happen.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="mailto:sponsor@cupcal.online"
            class="inline-block px-8 py-4 bg-yellow-300 text-black text-lg font-black uppercase tracking-wider border-[4px] border-white shadow-[6px_6px_0px_rgba(255,255,255,0.3)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] transition-all"
            style="font-family: 'Anton', sans-serif;"
          >
            ✉️ GET IN TOUCH
          </a>
          <a
            href="https://instagram.com/hammaadworks"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 bg-pink-500 text-white text-lg font-black uppercase tracking-wider border-[4px] border-white shadow-[6px_6px_0px_rgba(255,255,255,0.3)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] transition-all"
            style="font-family: 'Anton', sans-serif;"
          >
            📸 @HAMMAADWORKS
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="py-12 border-t-[4px] border-black relative z-20 bg-yellow-300">
    <div class="container px-4 mx-auto text-center">
      <p class="text-black text-xl font-anton uppercase tracking-widest mb-6">
        Cooked up with Alhamdulillah by <a href="https://hammaadworks.com" class="text-pink-600 hover:text-black border-b-[3px] border-pink-600 hover:border-black transition-colors">hammaadworks</a>
      </p>
      <div class="flex justify-center gap-6">
        <a href="https://x.com/hammaadworks" class="text-black font-anton uppercase tracking-widest text-xl hover:text-pink-600 transition-colors">X</a>
        <a href="https://github.com/hammaadworks" class="text-black font-anton uppercase tracking-widest text-xl hover:text-pink-600 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</BaseLayout>
