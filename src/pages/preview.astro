---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Preview Mode">
  <div class="fixed inset-0 z-[100] bg-brand-primary/80 backdrop-blur-sm flex flex-col items-center justify-center p-4">
    <div class="bg-white border-[4px] border-black p-8 max-w-lg w-full text-center shadow-[8px_8px_0px_#2E0D23] relative">
      <h1 class="text-3xl md:text-4xl font-outfit uppercase tracking-widest text-black mb-4">
        We are live on Beta! 🚀
      </h1>
      <p class="text-lg font-medium text-black/80 mb-6 font-inter">
        Thank you for checking out Cupcal.<br/><br/>
        We have now moved to our official home:<br/>
        <strong class="text-blue-600 font-bold text-xl">cupcal.online</strong><br/><br/>
        You'll be redirected automatically in <span id="countdown" class="font-bold">3</span> seconds.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a 
          href="https://cupcal.online" 
          class="bg-blue-600 hover:bg-blue-700 text-white font-outfit text-xl uppercase tracking-widest px-6 py-3 border-[2px] border-black shadow-[4px_4px_0px_#2E0D23] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all inline-block w-full"
        >
          Go to Cupcal.online →
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  let timeLeft = 3;
  
  const countdownEl = document.getElementById('countdown');

  function updateRedirect() {
    if (timeLeft <= 0) {
      window.location.href = 'https://cupcal.online';
    } else {
      if (countdownEl) countdownEl.innerText = timeLeft.toString();
      timeLeft--;
      setTimeout(updateRedirect, 1000);
    }
  }

  // Start the countdown
  setTimeout(updateRedirect, 1000);
</script>
