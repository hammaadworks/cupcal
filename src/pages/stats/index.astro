---
import BaseLayout from '../../layouts/BaseLayout.astro';

// For now, mock custom data points until we hook them up to Supabase fully
const customStats = [
  { label: "Matches Viewed", value: "24,592", icon: "⚽️" },
  { label: "Reminders Set", value: "8,301", icon: "⏰" },
  { label: "Watch Parties Found", value: "1,204", icon: "🎉" },
  { label: "Tickets Scanned", value: "4,500", icon: "🎟️" }
];

const socialStats = [
  { platform: "Instagram", label: "Reels Views", value: "125K+", icon: "📱" },
  { platform: "YouTube", label: "Shorts Views", value: "89K+", icon: "▶️" }
];

// Umami Public Share URL
const UMAMI_SHARE_URL = "https://umami-cc.vercel.app/share/OySWXozMG2JKu5eI";
---

<BaseLayout title="Open Stats">
	<main class="min-h-screen relative z-10 overflow-x-clip w-full bg-[#f3f4f6]">
		<section class="pt-12 pb-8 container px-4 mx-auto">
			<div class="max-w-5xl mx-auto">
				<h1 class="text-5xl md:text-7xl font-anton text-center mb-6 tracking-tighter uppercase text-black">
					Open <span class="text-pink-500">Stats</span>
				</h1>
				<p class="text-center text-xl font-medium mb-12 text-black/80 max-w-2xl mx-auto">
					We build in public. Here's exactly how many football fans we are reaching across the globe. 
				</p>

                <!-- Custom App Data Points -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
                    {customStats.map(stat => (
                        <div class="bg-white border-[3px] border-black p-6 rounded-xl shadow-[4px_4px_0px_#000] text-center hover:-translate-y-1 hover:shadow-[6px_6px_0px_#000] transition-all">
                            <div class="text-4xl mb-2">{stat.icon}</div>
                            <div class="text-3xl font-anton text-black">{stat.value}</div>
                            <div class="text-sm font-bold uppercase text-gray-600 tracking-wide mt-1">{stat.label}</div>
                        </div>
                    ))}
                </div>

                <!-- Social Stats -->
                <h2 class="text-3xl font-anton uppercase text-black mb-6 text-center">Social Reach</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16 max-w-2xl mx-auto">
                     {socialStats.map(stat => (
                        <div class="bg-yellow-300 border-[3px] border-black p-6 rounded-xl shadow-[4px_4px_0px_#000] flex items-center justify-between hover:-translate-y-1 hover:shadow-[6px_6px_0px_#000] transition-all">
                            <div class="flex items-center gap-4">
                                <div class="text-4xl">{stat.icon}</div>
                                <div class="text-lg font-bold uppercase text-black tracking-wide">{stat.platform} {stat.label}</div>
                            </div>
                            <div class="text-3xl font-anton text-black">{stat.value}</div>
                        </div>
                    ))}
                </div>

                <!-- Umami Iframe Section -->
                <div class="bg-white border-[4px] border-black rounded-2xl shadow-[8px_8px_0px_#000] overflow-hidden relative">
                    <div class="bg-black text-white p-4 flex justify-between items-center">
                        <h2 class="text-2xl font-anton tracking-wide uppercase m-0 flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
                            Live Traffic
                        </h2>
                        <a href={UMAMI_SHARE_URL} target="_blank" rel="noopener noreferrer" class="bg-pink-500 hover:bg-pink-400 text-black font-bold py-2 px-4 rounded border-[2px] border-black shadow-[2px_2px_0px_#fff] transition-all text-sm uppercase flex items-center gap-2">
                            View Raw Source <span aria-hidden="true">↗</span>
                        </a>
                    </div>
                    <!-- The iframe loads the Umami dashboard -->
                    <div class="w-full h-[600px] bg-gray-50 flex items-center justify-center">
                        <iframe 
                            src={UMAMI_SHARE_URL} 
                            class="w-full h-full border-none"
                            title="Umami Public Dashboard"
                        ></iframe>
                    </div>
                </div>

                <div class="text-center mt-12 mb-20">
                    <p class="text-lg font-medium text-black">Interested in reaching these fans?</p>
                    <a href="mailto:hammaadworks@gmail.com" class="inline-block mt-4 bg-black text-white font-anton text-2xl uppercase tracking-widest py-3 px-8 rounded-full hover:bg-pink-500 hover:text-black transition-colors shadow-[4px_4px_0px_#pink-500]">
                        Sponsor Us
                    </a>
                </div>

			</div>
		</section>
	</main>
</BaseLayout>
