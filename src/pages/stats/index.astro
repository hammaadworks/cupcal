---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../utils/supabase';

// Fetching REAL metrics from Supabase to maintain absolute transparency
const { count: ticketsSold } = await supabase
  .from('tickets')
  .select('*', { count: 'exact', head: true });

const { count: matchesCount } = await supabase
  .from('matches')
  .select('*', { count: 'exact', head: true });

const realStats = [
  { label: "Matches Scheduled", value: matchesCount || 104, icon: "⚽️" },
  { label: "Tickets Sold", value: ticketsSold || 0, icon: "🎟️" },
];

// Umami Public Share URL
const UMAMI_SHARE_URL = "https://umami-cc.vercel.app/share/OySWXozMG2JKu5eI";
---

<BaseLayout title="Open Stats">
	<main class="min-h-screen relative z-10 overflow-x-clip w-full bg-[#f3f4f6]">
		<section class="pt-12 pb-8 container px-4 mx-auto">
			<div class="max-w-5xl mx-auto">
				<h1 class="text-5xl md:text-7xl font-anton text-center mb-6 tracking-tighter uppercase text-black">
					Open <span class="text-pink-500">Stats</span>
				</h1>
				<p class="text-center text-xl font-medium mb-12 text-black/80 max-w-2xl mx-auto">
					We build in public with zero inflated metrics. What you see is exactly what our database and analytics are recording.
				</p>

                <!-- REAL App Data Points -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 max-w-3xl mx-auto">
                    {realStats.map(stat => (
                        <div class="bg-white border-[4px] border-black p-8 rounded-2xl shadow-[8px_8px_0px_#000] text-center">
                            <div class="text-6xl mb-4">{stat.icon}</div>
                            <div class="text-5xl font-anton text-black">{stat.value.toLocaleString()}</div>
                            <div class="text-lg font-bold uppercase text-gray-600 tracking-wide mt-2">{stat.label}</div>
                        </div>
                    ))}
                </div>

                <!-- Umami Authenticity Link (No Iframe to avoid Vercel blocking) -->
                <div class="bg-yellow-300 border-[4px] border-black rounded-2xl shadow-[8px_8px_0px_#000] overflow-hidden relative max-w-3xl mx-auto p-12 text-center">
                    <div class="w-16 h-16 bg-white border-[3px] border-black rounded-full flex items-center justify-center mx-auto mb-6 shadow-[4px_4px_0px_#000]">
                        <span class="w-6 h-6 rounded-full bg-red-500 animate-pulse"></span>
                    </div>
                    
                    <h2 class="text-4xl md:text-5xl font-anton tracking-wide uppercase text-black mb-4">
                        Live Traffic & Analytics
                    </h2>
                    <p class="text-xl font-medium text-black/80 mb-8 max-w-xl mx-auto">
                        To prove the authenticity of our traffic and engagement (including calendar syncs), we have opened our raw Umami analytics dashboard to the public.
                    </p>

                    <!-- Live Dynamic Screenshot of the Umami Dashboard -->
                    <div class="mb-8 border-[3px] border-black rounded-xl overflow-hidden shadow-[4px_4px_0px_#000] max-w-2xl mx-auto">
                        <img 
                            src="https://api.microlink.io/?url=https%3A%2F%2Fumami-cc.vercel.app%2Fshare%2FOySWXozMG2JKu5eI&screenshot=true&embed=screenshot.url" 
                            alt="Live Umami Analytics Dashboard Preview" 
                            class="w-full h-auto object-cover opacity-90 hover:opacity-100 transition-opacity"
                            loading="lazy"
                        />
                    </div>
                    
                    <a href={UMAMI_SHARE_URL} target="_blank" rel="noopener noreferrer" class="inline-block bg-pink-500 hover:bg-black text-white font-anton text-2xl uppercase tracking-widest py-4 px-10 rounded-full border-[4px] border-black shadow-[6px_6px_0px_#000] hover:shadow-[8px_8px_0px_#pink-500] hover:-translate-y-1 transition-all">
                        Launch Live Dashboard <span aria-hidden="true" class="ml-2">↗</span>
                    </a>
                </div>

                <div class="text-center mt-20 mb-20">
                    <p class="text-xl font-medium text-black">Interested in reaching these fans?</p>
                    <a href="mailto:hammaadworks@gmail.com" class="inline-block mt-6 bg-black text-white font-anton text-2xl uppercase tracking-widest py-4 px-10 rounded-full hover:bg-pink-500 hover:text-black transition-colors shadow-[6px_6px_0px_#pink-500]">
                        Sponsor Us
                    </a>
                </div>

			</div>
		</section>
	</main>
</BaseLayout>
