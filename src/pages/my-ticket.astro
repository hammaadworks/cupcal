---
import BaseLayout from '../layouts/BaseLayout.astro';
import TicketLookup from '../components/TicketLookup';
---

<BaseLayout title="Find My Ticket" description="Look up your FIFA World Cup 2026 Finals Watch Party ticket.">
  <main class="min-h-screen py-12 md:py-20 px-4 relative overflow-hidden">
    <div class="bg-typography-container">
      <div class="bg-text-line">TICKET TICKET TICKET TICKET</div>
      <div class="bg-text-line">LOOKUP LOOKUP LOOKUP LOOKUP</div>
      <div class="bg-text-line">TICKET TICKET TICKET TICKET</div>
    </div>

    <div class="container mx-auto max-w-xl relative z-20">
      <div class="text-center mb-12">
        <div class="inline-block py-2 px-5 mb-6 text-sm font-black tracking-widest text-black uppercase bg-yellow-300 border-[3px] border-black shadow-[4px_4px_0px_#2E0D23]">
          🎫 Ticket Lookup
        </div>
        <h1 class="text-4xl md:text-6xl font-outfit text-white uppercase tracking-tighter leading-none mb-4">
          Find My Ticket
        </h1>
        <p class="text-lg text-white/80 font-medium bg-black/50 backdrop-blur-sm p-4 border-[3px] border-white/20">
          Enter your email or WhatsApp number to retrieve your ticket.
        </p>
      </div>

      <TicketLookup client:load />

      <!-- Back to home -->
      <div class="text-center mt-12">
        <a href="/" class="text-white font-bold underline decoration-[3px] decoration-blue-600 hover:decoration-white transition-colors text-sm uppercase tracking-widest">
          ← Back to Home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
