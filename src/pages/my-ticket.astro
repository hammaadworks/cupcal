---
import BaseLayout from '../layouts/BaseLayout.astro';
import TicketLookup from '../components/TicketLookup';
---

<BaseLayout title="Find My Ticket" description="Look up your FIFA World Cup 2026 Finals Watch Party ticket.">
  <main class="min-h-screen py-12 md:py-20 px-4 bg-pink-100 relative overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -right-20 w-72 h-72 bg-yellow-300 rounded-full opacity-20 blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-pink-400 rounded-full opacity-20 blur-3xl"></div>
    </div>

    <div class="container mx-auto max-w-xl relative z-20">
      <div class="text-center mb-12">
        <div class="inline-block py-2 px-5 mb-6 text-sm font-black tracking-widest text-black uppercase bg-yellow-300 border-[3px] border-black shadow-[4px_4px_0px_#000]">
          🎫 Ticket Lookup
        </div>
        <h1 class="text-4xl md:text-6xl font-anton text-black uppercase tracking-tighter leading-none mb-4">
          Find My Ticket
        </h1>
        <p class="text-lg text-black font-medium">
          Enter your email or WhatsApp number to retrieve your ticket.
        </p>
      </div>

      <TicketLookup client:load />

      <!-- Back to home -->
      <div class="text-center mt-12">
        <a href="/" class="text-black font-bold underline decoration-[3px] decoration-pink-500 hover:decoration-black transition-colors text-sm uppercase tracking-widest">
          ← Back to Home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
