---
import BaseLayout from '../../layouts/BaseLayout.astro';
import faqData from '../../data/seo/faq.json';
---

<BaseLayout title="Frequently Asked Questions" description="Everything you need to know about the 2026 Global Football Tournament.">
	<main class="min-h-screen relative z-10 overflow-x-clip w-full">
		<section class="py-20 border-b-[3px] border-black relative z-20 bg-[#a7f3d0]">
			<div class="container px-4 mx-auto max-w-4xl">
				<h1 class="text-4xl md:text-6xl font-outfit text-center mb-12 text-black uppercase tracking-tight">SPILL THE TEA (FAQ)</h1>
				<p class="text-xl font-bold mb-8 uppercase tracking-widest text-black text-center">Your ultimate guide to surviving and thriving in 2026.</p>
				<div class="grid gap-6">
					{faqData.map((faq) => (
						<a href={`/faq/${faq.slug}`} class="group p-6 bg-white border-[3px] border-black rounded-xl shadow-[4px_4px_0px_#2E0D23] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_#2E0D23] transition-all">
							<h3 class="text-xl font-bold text-black group-hover:text-blue-600 transition-colors uppercase font-outfit tracking-wide">
								{faq.question}
							</h3>
							<p class="mt-2 text-black font-medium line-clamp-3">
								{faq.answer}
							</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
