---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit Watch Party" description="Submit an ethical, family-friendly Global Tournament screening venue.">
  <main class="cyber-grid min-h-screen py-20 px-4">
    <div class="container mx-auto max-w-2xl relative z-20">
      <a href="/watch-party" class="text-green-400 hover:text-green-300 mb-8 inline-block font-bold tracking-widest uppercase text-sm border border-green-500/30 px-4 py-2 rounded-full backdrop-blur-sm shadow-[0_0_15px_rgba(34,197,94,0.1)]">← Back to Directory</a>
      
      <div class="bg-black/40 rounded-3xl border border-white/10 shadow-2xl overflow-hidden backdrop-blur-md">
        <div class="bg-white/5 border-b border-white/10 p-8 text-white text-center">
          <h1 class="text-3xl font-black mb-2 uppercase tracking-wide" style="font-family: 'Anton', sans-serif;">Submit a Venue</h1>
          <p class="text-slate-400">Help the community find safe places to watch.</p>
        </div>

        <form class="p-8 space-y-6" id="submitForm">
          <div>
            <label class="block text-sm font-bold text-white mb-2 tracking-wide">Venue Name</label>
            <input type="text" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:ring-2 focus:ring-green-500 outline-none transition-all placeholder-slate-500 shadow-inner" placeholder="e.g. Community Center Hall" />
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold text-white mb-2 tracking-wide">City</label>
              <input type="text" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:ring-2 focus:ring-green-500 outline-none transition-all placeholder-slate-500 shadow-inner" placeholder="e.g. London" />
            </div>
            <div>
              <label class="block text-sm font-bold text-white mb-2 tracking-wide">Country</label>
              <input type="text" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:ring-2 focus:ring-green-500 outline-none transition-all placeholder-slate-500 shadow-inner" placeholder="e.g. UK" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-white mb-2 tracking-wide">Description / Facilities</label>
            <textarea required rows="3" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:ring-2 focus:ring-green-500 outline-none transition-all placeholder-slate-500 shadow-inner" placeholder="Describe the screen size, food options, prayer facilities, etc."></textarea>
          </div>

          <div class="bg-amber-500/10 border border-amber-500/30 p-6 rounded-2xl">
            <h3 class="font-bold text-amber-400 mb-4 flex items-center gap-2">
              ⚠️ The Ethical Pledge
            </h3>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" required class="mt-1 w-5 h-5 text-green-500 border-white/20 rounded focus:ring-green-500 bg-white/10" />
              <span class="text-sm text-slate-300 font-medium">
                I certify that this venue is 100% family-friendly and operates an alcohol-free environment during the Global Tournament screenings.
              </span>
            </label>
          </div>

          <button type="submit" class="w-full py-4 bg-green-500 text-[#041006] font-black rounded-xl hover:bg-green-400 transition-all text-lg uppercase tracking-widest shadow-[0_0_20px_rgba(34,197,94,0.4)]">
            Submit for Review
          </button>
        </form>
      </div>
    </div>
  </main>
  
  <script>
    document.getElementById('submitForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('This is a static preview. Backend integration (Neon DB) is required to save entries. Your form looks great though!');
    });
  </script>
</BaseLayout>
