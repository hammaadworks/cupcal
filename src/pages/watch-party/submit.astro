---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit Watch Party" description="Submit an ethical, family-friendly Global Tournament screening venue.">
  <main class="min-h-screen py-20 px-4 relative z-10 overflow-x-clip">
    <div class="bg-typography-container">
      <div class="bg-text-line">SUBMIT SUBMIT SUBMIT SUBMIT</div>
      <div class="bg-text-line">VENUE VENUE VENUE VENUE</div>
      <div class="bg-text-line">SUBMIT SUBMIT SUBMIT SUBMIT</div>
      <div class="bg-text-line">VENUE VENUE VENUE VENUE</div>
      <div class="bg-text-line">SUBMIT SUBMIT SUBMIT SUBMIT</div>
    </div>

    <div class="container mx-auto max-w-3xl relative z-20">
      <a href="/watch-party" class="text-white hover:text-yellow-300 mb-8 inline-block font-black tracking-widest uppercase text-sm border-[3px] border-white px-6 py-3 bg-black hover:-translate-y-1 hover:shadow-[4px_4px_0px_#fde047] transition-all">← Back to Directory</a>
      
      <div class="bg-white border-[4px] border-black shadow-[12px_12px_0px_#2E0D23] p-8 md:p-12">
        <div class="border-b-[4px] border-black pb-8 mb-8 text-center">
          <span class="inline-block py-1 px-3 mb-4 text-xs font-black tracking-widest text-black uppercase bg-yellow-300 border-[3px] border-black shadow-[4px_4px_0px_#2E0D23]">Community Built</span>
          <h1 class="text-4xl md:text-6xl font-black mb-4 uppercase tracking-tighter text-black">Submit a Venue</h1>
          <p class="text-xl font-bold text-gray-700 uppercase tracking-widest">Help the community find safe places to watch.</p>
        </div>

        <form class="space-y-8" id="submitForm">
          <div>
            <label class="block text-xl font-black text-black mb-4 uppercase tracking-widest">Venue Name</label>
            <input type="text" required class="w-full px-6 py-4 bg-gray-50 border-[3px] border-black text-black font-bold focus:bg-yellow-100 outline-none transition-all placeholder-gray-400 shadow-[4px_4px_0px_#2E0D23] text-lg uppercase tracking-widest" placeholder="e.g. Community Center Hall" />
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <label class="block text-xl font-black text-black mb-4 uppercase tracking-widest">City</label>
              <input type="text" required class="w-full px-6 py-4 bg-gray-50 border-[3px] border-black text-black font-bold focus:bg-yellow-100 outline-none transition-all placeholder-gray-400 shadow-[4px_4px_0px_#2E0D23] text-lg uppercase tracking-widest" placeholder="e.g. London" />
            </div>
            <div>
              <label class="block text-xl font-black text-black mb-4 uppercase tracking-widest">Country</label>
              <input type="text" required class="w-full px-6 py-4 bg-gray-50 border-[3px] border-black text-black font-bold focus:bg-yellow-100 outline-none transition-all placeholder-gray-400 shadow-[4px_4px_0px_#2E0D23] text-lg uppercase tracking-widest" placeholder="e.g. UK" />
            </div>
          </div>

          <div>
            <label class="block text-xl font-black text-black mb-4 uppercase tracking-widest">Description / Facilities</label>
            <textarea required rows="4" class="w-full px-6 py-4 bg-gray-50 border-[3px] border-black text-black font-bold focus:bg-yellow-100 outline-none transition-all placeholder-gray-400 shadow-[4px_4px_0px_#2E0D23] text-lg resize-none uppercase tracking-widest" placeholder="Describe the screen size, food options, prayer facilities, etc."></textarea>
          </div>

          <div class="bg-blue-100 border-[4px] border-black p-8 shadow-[6px_6px_0px_#2E0D23]">
            <h3 class="font-black text-2xl text-black mb-6 uppercase tracking-widest bg-yellow-300 inline-block px-4 py-2 border-[3px] border-black shadow-[4px_4px_0px_#2E0D23]">
              ⚠️ The Ethical Pledge
            </h3>
            <label class="flex items-start gap-4 cursor-pointer mt-4">
              <input type="checkbox" required class="mt-2 w-6 h-6 border-[3px] border-black text-black focus:ring-0 bg-white" />
              <span class="text-lg text-black font-bold uppercase tracking-wider leading-relaxed">
                I certify that this venue is 100% family-friendly and operates an alcohol-free environment during the Global Tournament screenings.
              </span>
            </label>
          </div>

          <button type="submit" class="w-full py-6 bg-black text-white font-black text-2xl hover:bg-yellow-400 hover:text-black border-[4px] border-black transition-all uppercase tracking-widest shadow-[8px_8px_0px_#2E0D23] hover:translate-x-1 hover:translate-y-1 hover:shadow-[4px_4px_0px_#2E0D23]">
            Submit for Review
          </button>
        </form>
      </div>
    </div>
  </main>
  
  <script>
    document.getElementById('submitForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('This is a static preview. Backend integration (Neon DB) is required to save entries. Your form looks great though!');
    });
  </script>
</BaseLayout>
