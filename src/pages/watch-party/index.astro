---
import BaseLayout from '../../layouts/BaseLayout.astro';

// This would eventually be fetched from the Neon database where is_verified = true
const mockParties = [
  {
    id: 1,
    name: "Islamic Center of New York - Youth Hall",
    city: "New York",
    country: "USA",
    description: "Family-friendly screening of USA matches on a 150-inch projector. Food and drinks provided.",
    is_verified: true,
  },
  {
    id: 2,
    name: "Community Center Halal Lounge",
    city: "Toronto",
    country: "Canada",
    description: "Alcohol-free environment for families to enjoy the matches. Prayer facilities available.",
    is_verified: true,
  }
];
---

<BaseLayout title="Watch Party Directory" description="Find ethical, family-friendly, and alcohol-free 2026 Global Tournament screening locations near you.">
  <main class="min-h-screen py-20 px-4 bg-pink-100">
    <div class="container mx-auto max-w-4xl relative z-20">
      <div class="text-center mb-16">
        <span class="inline-block py-1 px-3 mb-4 text-xs font-black tracking-widest text-black uppercase bg-yellow-300 border-[3px] border-black shadow-[4px_4px_0px_#000]">Community Directory</span>
        <h1 class="text-4xl md:text-7xl font-black text-black mb-6 uppercase tracking-tighter" style="font-family: 'Anton', sans-serif;">Ethical Watch Parties</h1>
        <p class="text-xl text-black font-medium max-w-2xl mx-auto border-[3px] border-black bg-white p-4 shadow-[4px_4px_0px_#000]">
          Find family-friendly, alcohol-free screening locations for the 2026 Global Tournament. Built by the community, for the community.
        </p>
        <div class="mt-8">
          <a href="/watch-party/submit" class="inline-block px-8 py-4 text-lg font-black text-black bg-yellow-400 hover:bg-pink-400 border-[4px] border-black transition-all shadow-[6px_6px_0px_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_#000] uppercase tracking-wider">
            Submit a Venue
          </a>
        </div>
      </div>

      <div class="bg-white border-[4px] border-black shadow-[8px_8px_0px_#000] p-8">
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 border-b-[4px] border-black pb-6">
          <h2 class="text-3xl font-black text-black uppercase tracking-widest bg-yellow-300 px-4 py-2 border-[3px] border-black shadow-[4px_4px_0px_#000]" style="font-family: 'Anton', sans-serif;">Verified Locations</h2>
          <input type="text" placeholder="SEARCH BY CITY..." class="w-full md:w-64 px-4 py-3 bg-white border-[3px] border-black text-black font-bold uppercase tracking-widest focus:outline-none focus:bg-pink-100 placeholder-gray-500 shadow-[4px_4px_0px_#000]" />
        </div>

        <div class="grid gap-6">
          {mockParties.map(party => (
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between p-6 border-[3px] border-black bg-yellow-50 hover:bg-pink-100 transition-all shadow-[4px_4px_0px_#000] group">
              <div class="mb-4 md:mb-0">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-2xl font-black text-black uppercase tracking-tight" style="font-family: 'Anton', sans-serif;">{party.name}</h3>
                  <span class="text-[10px] bg-green-400 text-black border-[2px] border-black px-2 py-1 font-black uppercase tracking-widest shadow-[2px_2px_0px_#000]">Verified</span>
                </div>
                <p class="text-black font-bold mb-2 flex items-center gap-2 text-sm uppercase tracking-widest">
                  <span>📍</span> {party.city}, {party.country}
                </p>
                <p class="text-gray-800 text-sm max-w-lg font-medium">{party.description}</p>
              </div>
              <button class="px-6 py-3 bg-white text-black border-[3px] border-black font-black hover:bg-yellow-300 transition-colors shrink-0 uppercase tracking-widest text-xs shadow-[4px_4px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_#000]">
                Get Details
              </button>
            </div>
          ))}
          {mockParties.length === 0 && (
            <div class="text-center py-12 text-black font-bold border-[3px] border-black border-dashed bg-gray-100 uppercase tracking-widest">
              No watch parties listed yet. Be the first to submit one!
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
