---
import BaseLayout from '../layouts/BaseLayout.astro';
import TournamentTree from '../components/TournamentTree';
import { getMatches } from '../utils/matches';

const matches = await getMatches();
---

<BaseLayout title="Tournament Tree - Knockout Stage">
	<main class="min-h-screen relative z-10 w-full pt-12 pb-24">
        <div class="bg-typography-container">
            <div class="bg-text-line">ROAD TO GLORY ROAD TO GLORY ROAD TO GLORY</div>
            <div class="bg-text-line">KNOCKOUTS KNOCKOUTS KNOCKOUTS KNOCKOUTS</div>
            <div class="bg-text-line">FINAL BOSS FINAL BOSS FINAL BOSS FINAL BOSS</div>
            <div class="bg-text-line">ROAD TO GLORY ROAD TO GLORY ROAD TO GLORY</div>
            <div class="bg-text-line">KNOCKOUTS KNOCKOUTS KNOCKOUTS KNOCKOUTS</div>
        </div>
        <div class="container px-4 mx-auto text-center mb-8 relative z-20">
            <a href="/" class="inline-block text-xl font-outfit uppercase tracking-widest text-white hover:text-gray-300 transition-colors mb-8">
                ← Back to Schedule
            </a>
            <h1 class="text-6xl md:text-8xl font-heading text-center tracking-tighter leading-none mb-4 uppercase">
                THE FINAL BOSS STAGE
            </h1>
            <p class="text-xl font-bold uppercase tracking-widest text-gray-500 max-w-2xl mx-auto">
                Filter by your favorite squad to see their path to glory.
            </p>
        </div>
        
		<section id="bracket" class="relative z-20">
			<div class="container px-4 mx-auto">
				<TournamentTree client:load matches={matches} />
			</div>
		</section>
	</main>
</BaseLayout>
