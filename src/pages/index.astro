---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScheduleFilter from '../components/ScheduleFilter';
import TournamentTree from '../components/TournamentTree';
import faqData from '../data/seo/faq.json';
import { getMatches } from '../utils/matches';

// Fetch matches
const matches = await getMatches();
---

<BaseLayout title="Official Schedule 2026">
	<main class="min-h-screen relative z-10 overflow-x-clip w-full">
        <div class="bg-typography-container">
            <div class="bg-text-line">WORLD CUP 2026 WORLD CUP 2026 WORLD CUP 2026</div>
            <div class="bg-text-line">CANADA MEXICO USA CANADA MEXICO USA</div>
            <div class="bg-text-line">FOOTBALL SOCCER FOOTBALL SOCCER FOOTBALL</div>
            <div class="bg-text-line">WORLD CUP 2026 WORLD CUP 2026 WORLD CUP 2026</div>
            <div class="bg-text-line">CANADA MEXICO USA CANADA MEXICO USA</div>
        </div>

		<section id="schedule" class="pt-8 pb-10 container px-4 mx-auto relative z-20">
			<div class="max-w-4xl mx-auto">
                <h1 class="text-6xl md:text-8xl font-heading text-center mb-12 tracking-tighter leading-none">
                    THE ULTIMATE<br/>FOOTBALL<br/>VIBES
                </h1>

				<ScheduleFilter client:load matches={matches} />
			</div>
		</section>

		<section id="bracket-link" class="py-20 border-y-[3px] border-black relative z-20 bg-white">
			<div class="container px-4 mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-outfit mb-6 text-black uppercase tracking-tight">Knockout SZN</h2>
				<p class="text-xl font-bold mb-8 uppercase tracking-widest text-black">See the full path to glory in the interactive tree.</p>
				<a href="/tree" class="inline-block bg-black text-white font-outfit text-2xl uppercase tracking-widest px-8 py-4 rounded-xl border-[4px] border-black shadow-[6px_6px_0px_#fbcfe8] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_#fbcfe8] transition-all">
					View Tournament Tree →
				</a>
			</div>
		</section>

	</main>
</BaseLayout>
