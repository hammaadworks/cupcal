---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScheduleFilter from '../components/ScheduleFilter';
import TournamentTree from '../components/TournamentTree';
import faqData from '../data/seo/faq.json';
import { getMatches } from '../utils/matches';

// Fetch matches
const matches = await getMatches();
---

<BaseLayout title="Official Schedule 2026">
	<main class="min-h-screen relative z-10 overflow-x-hidden w-full">
        <div class="bg-typography-container">
            <div class="bg-text-line">WORLD CUP 2026 WORLD CUP 2026 WORLD CUP 2026</div>
            <div class="bg-text-line">CANADA MEXICO USA CANADA MEXICO USA</div>
            <div class="bg-text-line">FOOTBALL SOCCER FOOTBALL SOCCER FOOTBALL</div>
            <div class="bg-text-line">WORLD CUP 2026 WORLD CUP 2026 WORLD CUP 2026</div>
            <div class="bg-text-line">CANADA MEXICO USA CANADA MEXICO USA</div>
        </div>

		<section id="schedule" class="pt-8 pb-10 container px-4 mx-auto relative z-20">
			<div class="max-w-4xl mx-auto">
                <h1 class="text-6xl md:text-8xl font-anton text-center mb-12 tracking-tighter leading-none">
                    THE ULTIMATE<br/>FOOTBALL<br/>VIBES
                </h1>

				<ScheduleFilter client:load matches={matches} />
			</div>
		</section>

		<section id="bracket-link" class="py-20 border-y-[3px] border-black relative z-20 bg-[#ffd6e0]">
			<div class="container px-4 mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-anton mb-6 text-black uppercase tracking-tight">Knockout SZN</h2>
				<p class="text-xl font-bold mb-8 uppercase tracking-widest text-black">See the full path to glory in the interactive bracket.</p>
				<a href="/tree" class="inline-block bg-black text-white font-anton text-2xl uppercase tracking-widest px-8 py-4 rounded-xl border-[4px] border-black shadow-[6px_6px_0px_#fbcfe8] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_#fbcfe8] transition-all">
					View Tournament Tree →
				</a>
			</div>
		</section>

		<section class="py-20 border-b-[3px] border-black relative z-20 bg-[#a7f3d0]">
			<div class="container px-4 mx-auto max-w-4xl">
				<h2 class="text-4xl md:text-5xl font-anton text-center mb-12 text-black uppercase tracking-tight">SPILL THE TEA (FAQ)</h2>
				<div class="grid gap-6">
					{faqData.slice(0, 6).map((faq) => (
						<a href={`/faq/${faq.slug}`} class="group p-6 bg-white border-[3px] border-black rounded-xl shadow-[4px_4px_0px_#000] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_#000] transition-all">
							<h3 class="text-xl font-bold text-black group-hover:text-pink-500 transition-colors uppercase font-anton tracking-wide">
								{faq.question}
							</h3>
							<p class="mt-2 text-black font-medium line-clamp-2">
								{faq.answer}
							</p>
						</a>
					))}
				</div>
				<div class="text-center mt-12">
					<p class="text-black font-bold">Still confused? Check out the full lore in our FAQ.</p>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
