---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../utils/supabase';

const { id } = Astro.params;

// Fetch the ticket
const { data: ticket } = await supabase
  .from('finals_tickets')
  .select('*, finals_events(*)')
  .eq('id', id)
  .eq('payment_status', 'paid')
  .single();

if (!ticket) {
  return Astro.redirect('/my-ticket?error=not-found');
}

// Mask email: h***d@gmail.com
function maskEmail(email: string): string {
  const [local, domain] = email.split('@');
  if (local.length <= 2) return `${local[0]}***@${domain}`;
  return `${local[0]}***${local[local.length - 1]}@${domain}`;
}

// Get first 8 chars of UUID for display
const shortId = ticket.id.substring(0, 8).toUpperCase();
const maskedEmail = maskEmail(ticket.email);
const eventName = ticket.finals_events?.name || 'FIFA WORLD CUP 2026 FINALS';
const eventDescription = ticket.finals_events?.description || 'LIVE SCREENING · BANGALORE';

// Format the purchase date
const purchaseDate = new Date(ticket.created_at).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<BaseLayout title="Your Ticket" description="Your confirmed ticket for the FIFA World Cup 2026 Finals Watch Party.">
  <main class="min-h-screen py-12 md:py-20 px-4 bg-pink-100 relative overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -left-20 w-72 h-72 bg-yellow-300 rounded-full opacity-20 blur-3xl"></div>
      <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-pink-400 rounded-full opacity-20 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/4 w-48 h-48 bg-green-300 rounded-full opacity-15 blur-3xl"></div>
    </div>

    <div class="container mx-auto max-w-lg relative z-20">
      <!-- Confirmed Header -->
      <div class="text-center mb-10">
        <div class="inline-block py-2 px-5 mb-6 text-sm font-black tracking-widest text-black uppercase bg-green-400 border-[3px] border-black shadow-[4px_4px_0px_#000] animate-bounce">
          CONFIRMED ✅
        </div>
        <h1 class="text-4xl md:text-6xl font-anton text-black uppercase tracking-tighter leading-none mb-4">
          YOUR TICKET IS<br/>CONFIRMED 🎉
        </h1>
        <p class="text-lg text-black font-medium">You're in! Here's your golden ticket.</p>
      </div>

      <!-- THE TICKET CARD -->
      <div class="ticket-card-wrapper mb-10">
        <!-- Top colored strip -->
        <div class="bg-black text-white px-6 py-4 border-[4px] border-black border-b-0 flex items-center justify-between"
             style="background: linear-gradient(135deg, #ec4899, #000000 60%);">
          <div class="flex items-center gap-3">
            <span class="text-2xl">⚽</span>
            <span class="font-anton text-xl tracking-widest uppercase text-white">pitch<span class="text-yellow-300">26</span></span>
          </div>
          <span class="font-anton text-xs tracking-widest text-pink-200 uppercase">Admit One</span>
        </div>

        <!-- Main Ticket Body -->
        <div class="bg-white border-[4px] border-black border-t-0 relative">
          <!-- Dashed tear-off line (left side) -->
          <div class="absolute left-0 top-0 bottom-0 w-0 border-l-[3px] border-dashed border-gray-400 ml-10 hidden md:block"></div>

          <!-- Ticket Content -->
          <div class="p-6 md:p-8 md:pl-16">
            <!-- Event Name -->
            <div class="mb-6">
              <h2 class="text-2xl md:text-3xl font-anton text-black uppercase tracking-tight leading-tight">
                FIFA WORLD CUP 2026<br/>FINALS WATCH PARTY
              </h2>
              <div class="mt-2 flex flex-wrap gap-2">
                <span class="inline-block py-1 px-3 text-[10px] font-black tracking-widest text-black uppercase bg-yellow-300 border-[2px] border-black shadow-[2px_2px_0px_#000]">
                  LIVE SCREENING
                </span>
                <span class="inline-block py-1 px-3 text-[10px] font-black tracking-widest text-black uppercase bg-pink-200 border-[2px] border-black shadow-[2px_2px_0px_#000]">
                  BANGALORE
                </span>
              </div>
            </div>

            <!-- Divider -->
            <div class="border-t-[3px] border-dashed border-black my-5"></div>

            <!-- Details Grid -->
            <div class="grid grid-cols-2 gap-y-5 gap-x-4 mb-6">
              <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-gray-500 mb-1">Attendee</p>
                <p class="text-sm font-bold text-black">{maskedEmail}</p>
              </div>
              <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-gray-500 mb-1">Ticket ID</p>
                <p class="text-sm font-bold text-black font-mono">#{shortId}</p>
              </div>
              <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-gray-500 mb-1">Purchased</p>
                <p class="text-sm font-bold text-black">{purchaseDate}</p>
              </div>
              <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-gray-500 mb-1">Status</p>
                <p class="text-sm font-bold text-green-600 flex items-center gap-1">
                  <span class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                  PAID
                </p>
              </div>
            </div>

            <!-- Divider -->
            <div class="border-t-[3px] border-dashed border-black my-5"></div>

            <!-- QR Code Section -->
            <div class="flex flex-col md:flex-row items-center gap-6">
              <div class="w-36 h-36 border-[3px] border-black bg-gray-50 flex items-center justify-center shadow-[4px_4px_0px_#000] shrink-0">
                <div class="text-center">
                  <div class="text-3xl mb-1">📱</div>
                  <p class="text-xs font-black text-gray-400 uppercase tracking-widest">QR CODE</p>
                </div>
              </div>
              <div class="text-center md:text-left">
                <p class="text-lg font-anton text-black uppercase tracking-wide mb-1">Show this at the entrance</p>
                <p class="text-xs text-gray-500 font-medium">Present this ticket on your phone or a printout at the venue gate for entry.</p>
              </div>
            </div>
          </div>

          <!-- Bottom decorative strip -->
          <div class="border-t-[3px] border-black bg-yellow-300 px-6 py-3 flex items-center justify-between">
            <div class="flex gap-2">
              {Array.from({ length: 8 }).map(() => (
                <div class="w-3 h-3 rounded-full bg-black opacity-20"></div>
              ))}
            </div>
            <span class="text-[10px] font-black tracking-widest uppercase text-black opacity-50">NO ALCOHOL · FAMILY FRIENDLY</span>
          </div>
        </div>

        <!-- Shadow effect for the card -->
        <div class="w-full h-2 bg-black -mt-[4px] mx-auto" style="width: calc(100% - 16px); margin-left: 8px;"></div>
        <div class="w-full h-2 bg-black -mt-[2px] mx-auto opacity-40" style="width: calc(100% - 32px); margin-left: 16px;"></div>
      </div>

      <!-- Save Reminder -->
      <div class="bg-white border-[4px] border-black shadow-[6px_6px_0px_#000] p-6 mb-8 text-center">
        <p class="text-xl font-anton text-black uppercase tracking-wide mb-2">📌 Save This Link!</p>
        <p class="text-sm text-gray-700 font-medium mb-4">
          Bookmark this page or take a screenshot. You'll need this ticket at the entrance.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <button
            onclick="navigator.clipboard.writeText(window.location.href).then(() => { const btn = document.getElementById('copy-btn'); btn.textContent = '✅ COPIED!'; setTimeout(() => btn.textContent = '📋 COPY LINK', 2000); })"
            id="copy-btn"
            class="px-6 py-3 bg-yellow-300 text-black border-[3px] border-black font-black uppercase tracking-widest text-xs shadow-[4px_4px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_#000] transition-all cursor-pointer"
          >
            📋 COPY LINK
          </button>
        </div>
      </div>

      <!-- Lost ticket link -->
      <div class="text-center">
        <a href="/my-ticket" class="text-black font-bold underline decoration-[3px] decoration-pink-500 hover:decoration-black transition-colors text-sm uppercase tracking-widest">
          Lost your ticket? Find it here →
        </a>
      </div>
    </div>
  </main>

  <style>
    .ticket-card-wrapper {
      filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.15));
    }

    @keyframes subtle-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }

    .ticket-card-wrapper:hover {
      animation: subtle-float 3s ease-in-out infinite;
    }

    /* Notch cutouts on the sides for physical ticket feel */
    .ticket-card-wrapper::before,
    .ticket-card-wrapper::after {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      background: #fce7f3; /* pink-100 to match page bg */
      border-radius: 50%;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }

    .ticket-card-wrapper {
      position: relative;
    }

    .ticket-card-wrapper::before {
      left: -10px;
      border-right: 3px solid black;
    }

    .ticket-card-wrapper::after {
      right: -10px;
      border-left: 3px solid black;
    }
  </style>
</BaseLayout>
