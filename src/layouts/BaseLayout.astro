---
import '../styles/global.css';
import SponsorBanner from '../components/SponsorBanner.astro';
import Footer from '../components/Footer.astro';
import MorphingLogo from '../components/MorphingLogo';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The clean, betting-free Global schedule for the 2026 Global Football Tournament." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title} | cupcal</title>
		<meta name="description" content={description} />
		<!-- Umami Analytics Script -->
		<script defer src="https://umami-cc.vercel.app/script.js" data-website-id="ec0060bb-9aef-41d4-af2b-954c6184a2e1"></script>
		<script>
			// Rotate favicon between host countries
			const favicons = ['/fifa_logo/canada.png', '/fifa_logo/usa.png', '/fifa_logo/mexico.png'];
			let faviconIndex = 0;
			setInterval(() => {
				faviconIndex = (faviconIndex + 1) % favicons.length;
				const link = document.querySelector("link[rel~='icon']");
				if (link) {
					link.href = favicons[faviconIndex];
				}
			}, 3000);
		</script>
	</head>
	<body class="bg-brand-primary text-text font-body selection:bg-pink-300 selection:text-black overflow-x-clip w-full relative">
		<nav class="bg-white border-b-[4px] border-black sticky top-0 z-50 shadow-[0_4px_0px_#000]">
			<div class="container mx-auto px-4 h-16 flex items-center justify-between">
				<a href="/" class="flex items-center gap-2 text-3xl font-anton text-black tracking-widest uppercase relative z-50">
					<MorphingLogo client:load className="w-10 h-10" />
					<span>cup<span class="text-pink-500">cal</span></span>
				</a>
				<div class="flex items-center gap-6">
					<div class="hidden md:flex items-center gap-6 mr-4">
						<a href="/tree" class="text-lg font-anton text-white bg-pink-500 hover:bg-pink-600 transition-colors uppercase tracking-widest border-[2px] border-black px-4 py-1 shadow-[2px_2px_0px_#000] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[4px_4px_0px_#000]">THE TREE</a>
						<a href="/watch-party" class="text-lg font-anton text-black hover:text-pink-500 transition-colors uppercase tracking-widest border-[2px] border-transparent hover:border-black px-3 py-1 rounded-full hover:shadow-[2px_2px_0px_#000] hover:-translate-y-1 hover:-translate-x-1">Watch Parties</a>
						<a href="/stats" class="text-lg font-anton text-black hover:text-pink-500 transition-colors uppercase tracking-widest border-[2px] border-transparent hover:border-black px-3 py-1 rounded-full hover:shadow-[2px_2px_0px_#000] hover:-translate-y-1 hover:-translate-x-1">Stats</a>
					</div>
					<button id="mobile-menu-btn" aria-label="Toggle Menu" class="md:hidden flex flex-col justify-center items-center w-10 h-10 border-[2px] border-black shadow-[2px_2px_0px_#000] bg-white active:translate-x-[2px] active:translate-y-[2px] active:shadow-[0px_0px_0px_#000] relative z-[60] group cursor-pointer transition-all">
						<span class="w-5 h-0.5 bg-black mb-1 transition-all group-[.open]:rotate-45 group-[.open]:translate-y-[6px]"></span>
						<span class="w-5 h-0.5 bg-black mb-1 transition-all group-[.open]:opacity-0"></span>
						<span class="w-5 h-0.5 bg-black transition-all group-[.open]:-rotate-45 group-[.open]:-translate-y-[6px]"></span>
					</button>
				</div>
			</div>
		</nav>

		<!-- Mobile Menu Overlay -->
		<div id="mobile-menu" class="fixed inset-0 bg-brand-primary z-40 translate-x-full transition-transform duration-300 md:hidden flex flex-col pt-24 px-6 gap-6 overscroll-contain overflow-y-auto pb-8">
			<a href="/tree" class="text-4xl font-anton text-white bg-pink-500 text-center uppercase tracking-widest border-[4px] border-black py-4 shadow-[4px_4px_0px_#000] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#000] transition-all">THE TREE</a>
			<a href="/watch-party" class="text-4xl font-anton text-black text-center uppercase tracking-widest border-[4px] border-black bg-white py-4 shadow-[4px_4px_0px_#000] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#000] transition-all">Watch Parties</a>
			<a href="/stats" class="text-4xl font-anton text-black text-center uppercase tracking-widest border-[4px] border-black bg-white py-4 shadow-[4px_4px_0px_#000] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#000] transition-all">Stats</a>
		</div>

		<SponsorBanner />
		<slot />
		<Footer />

		<script>
			// Mobile menu toggle logic
			const setupMobileMenu = () => {
				const btn = document.getElementById('mobile-menu-btn');
				const menu = document.getElementById('mobile-menu');

				if (!btn || !menu) return;

				// Use a clean event listener approach
				const handleToggle = () => {
					const isOpen = btn.classList.contains('open');
					if (isOpen) {
						btn.classList.remove('open');
						menu.classList.add('translate-x-full');
						document.body.style.overflow = '';
					} else {
						btn.classList.add('open');
						menu.classList.remove('translate-x-full');
						document.body.style.overflow = 'hidden';
					}
				};

				// Remove old listener if exists to prevent duplicates on Astro page swaps
				btn.removeEventListener('click', handleToggle);
				btn.addEventListener('click', handleToggle);
			};

			setupMobileMenu();
			document.addEventListener('astro:page-load', setupMobileMenu);
		</script>
	</body>
</html>
