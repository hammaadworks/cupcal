---
import '../styles/global.css';
import SponsorBanner from '../components/SponsorBanner.astro';
import Footer from '../components/Footer.astro';
import MorphingLogo from '../components/MorphingLogo';
import TimezoneSelector from '../components/TimezoneSelector';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The clean, betting-free Global schedule for the 2026 Global Football Tournament." } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, ""); // Normalize path
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Anonymous+Pro:wght@400;700&family=Anton&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title} | cupcal</title>
		<meta name="description" content={description} />
		
		<!-- PWA Manifest -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#ffffff" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<link rel="apple-touch-icon" href="/favicon.jpg" />
		
		<!-- Umami Analytics Script -->
		<script defer src="https://umami-cc.vercel.app/script.js" data-website-id="ec0060bb-9aef-41d4-af2b-954c6184a2e1"></script>
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').then(registration => {
						console.log('SW registered:', registration);
					}).catch(registrationError => {
						console.log('SW registration failed:', registrationError);
					});
				});
			}

			// Rotate favicon between host countries
			const favicons = ['/fifa_logo/canada.png', '/fifa_logo/usa.png', '/fifa_logo/mexico.png'];
			let faviconIndex = 0;
			setInterval(() => {
				faviconIndex = (faviconIndex + 1) % favicons.length;
				const link = document.querySelector("link[rel~='icon']");
				if (link) {
					link.href = favicons[faviconIndex];
				}
			}, 3000);
		</script>
	</head>
	<body class="bg-[#041006] text-white font-body selection:bg-blue-300 selection:text-black overflow-x-clip w-full relative">
		<nav class="bg-gradient-to-r from-[#E51921] via-[#0A3161] to-[#00A859] border-b-[4px] border-black sticky top-0 z-50 shadow-[0_4px_0px_#2E0D23]">
			<div class="container mx-auto px-4 h-16 flex items-center justify-between">
				<a href="/" class="flex items-center gap-2 text-3xl font-display text-white tracking-widest uppercase relative z-50 shrink-0 drop-shadow-md">
					<MorphingLogo client:load className="w-8 h-8 md:w-10 md:h-10" />
					<span class="hidden sm:inline">cup<span class="text-blue-300">cal</span></span>
				</a>
				
				<div class="flex items-center justify-end flex-grow">
					<div class="hidden md:flex items-center justify-center flex-grow gap-2 lg:gap-6">
						<a href="/" class={`text-base lg:text-lg font-display uppercase tracking-widest border-[2px] px-3 py-1 rounded-full transition-all ${currentPath === '' ? 'bg-white text-black border-white shadow-[2px_2px_0px_rgba(255,255,255,0.3)] -translate-y-1' : 'text-white border-transparent hover:border-white hover:text-blue-200 hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] hover:-translate-y-1 hover:-translate-x-1'}`}>Home</a>
						<a href="/tree" class={`text-base lg:text-lg font-display uppercase tracking-widest border-[2px] px-3 py-1 rounded-full transition-all ${currentPath === '/tree' ? 'bg-white text-black border-white shadow-[2px_2px_0px_rgba(255,255,255,0.3)] -translate-y-1' : 'text-white border-transparent hover:border-white hover:text-blue-200 hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] hover:-translate-y-1 hover:-translate-x-1'}`}>Tree</a>
						<a href="/watch-party" class={`text-base lg:text-lg font-display uppercase tracking-widest border-[2px] px-3 py-1 rounded-full transition-all ${currentPath === '/watch-party' ? 'bg-white text-black border-white shadow-[2px_2px_0px_rgba(255,255,255,0.3)] -translate-y-1' : 'text-white border-transparent hover:border-white hover:text-blue-200 hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] hover:-translate-y-1 hover:-translate-x-1'}`}>Watch Parties</a>
						<a href="/stats" class={`text-base lg:text-lg font-display uppercase tracking-widest border-[2px] px-3 py-1 rounded-full transition-all ${currentPath === '/stats' ? 'bg-white text-black border-white shadow-[2px_2px_0px_rgba(255,255,255,0.3)] -translate-y-1' : 'text-white border-transparent hover:border-white hover:text-blue-200 hover:shadow-[2px_2px_0px_rgba(255,255,255,0.3)] hover:-translate-y-1 hover:-translate-x-1'}`}>Stats</a>
					</div>
					
					<div class="flex items-center gap-2 lg:gap-4 shrink-0">
						<div className="hidden sm:flex items-center gap-2">
							<TimezoneSelector client:load compact={true} />
						</div>
						<button id="mobile-menu-btn" aria-label="Toggle Menu" class="md:hidden flex flex-col justify-center items-center w-10 h-10 border-[2px] border-black shadow-[2px_2px_0px_#2E0D23] bg-white active:translate-x-[2px] active:translate-y-[2px] active:shadow-[0px_0px_0px_#2E0D23] relative z-[60] group cursor-pointer transition-all">
							<span class="w-5 h-0.5 bg-black mb-1 transition-all group-[.open]:rotate-45 group-[.open]:translate-y-[6px]"></span>
							<span class="w-5 h-0.5 bg-black mb-1 transition-all group-[.open]:opacity-0"></span>
							<span class="w-5 h-0.5 bg-black transition-all group-[.open]:-rotate-45 group-[.open]:-translate-y-[6px]"></span>
						</button>
					</div>
				</div>
			</div>
		</nav>

		<!-- Mobile Menu Overlay -->
		<div id="mobile-menu" class="fixed inset-0 bg-gradient-to-b from-[#E51921] via-[#0A3161] to-[#00A859] z-40 translate-x-full transition-transform duration-300 md:hidden flex flex-col pt-24 px-6 gap-6 overscroll-contain overflow-y-auto pb-8">
			<div className="flex flex-col gap-4 justify-center items-center mb-4 w-full">
				<TimezoneSelector client:load compact={false} />
			</div>
			<a href="/" class={`text-4xl font-display text-center uppercase tracking-widest border-[4px] border-black py-4 transition-all shadow-[4px_4px_0px_#2E0D23] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#2E0D23] ${currentPath === '' ? 'bg-black text-white' : 'bg-white text-black hover:bg-gray-100'}`}>Home</a>
			<a href="/tree" class={`text-4xl font-display text-center uppercase tracking-widest border-[4px] border-black py-4 transition-all shadow-[4px_4px_0px_#2E0D23] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#2E0D23] ${currentPath === '/tree' ? 'bg-black text-white' : 'bg-white text-black hover:bg-gray-100'}`}>Tree</a>
			<a href="/watch-party" class={`text-4xl font-display text-center uppercase tracking-widest border-[4px] border-black py-4 transition-all shadow-[4px_4px_0px_#2E0D23] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#2E0D23] ${currentPath === '/watch-party' ? 'bg-black text-white' : 'bg-white text-black hover:bg-gray-100'}`}>Watch Parties</a>
			<a href="/stats" class={`text-4xl font-display text-center uppercase tracking-widest border-[4px] border-black py-4 transition-all shadow-[4px_4px_0px_#2E0D23] active:translate-x-[4px] active:translate-y-[4px] active:shadow-[0px_0px_0px_#2E0D23] ${currentPath === '/stats' ? 'bg-black text-white' : 'bg-white text-black hover:bg-gray-100'}`}>Stats</a>
		</div>

		<SponsorBanner />
		<slot />
		<Footer />

		<script>
			// Mobile menu toggle logic
			const setupMobileMenu = () => {
				const btn = document.getElementById('mobile-menu-btn');
				const menu = document.getElementById('mobile-menu');

				if (!btn || !menu) return;

				// Use a clean event listener approach
				const handleToggle = () => {
					const isOpen = btn.classList.contains('open');
					if (isOpen) {
						btn.classList.remove('open');
						menu.classList.add('translate-x-full');
						document.body.style.overflow = '';
					} else {
						btn.classList.add('open');
						menu.classList.remove('translate-x-full');
						document.body.style.overflow = 'hidden';
					}
				};

				// Remove old listener if exists to prevent duplicates on Astro page swaps
				btn.removeEventListener('click', handleToggle);
				btn.addEventListener('click', handleToggle);
			};

			setupMobileMenu();
			document.addEventListener('astro:page-load', setupMobileMenu);
		</script>
	</body>
</html>
